{
  "name": "wedesignerz",
  "version": "1.0.0",
  "description": "We Designerz — сообщество вайбкодеров",
  "main": "js/main.js",
  "type": "module",
  "scripts": {
    "lint:js": "eslint '**/*.js'",
    "lint:js:fix": "eslint '**/*.js' --fix",
    "lint:css": "stylelint '**/*.css'",
    "lint:css:fix": "stylelint '**/*.css' --fix",
    "lint": "npm run lint:js && npm run lint:css",
    "security-check": "node scripts/security-check.mjs",
    "check:csp": "node scripts/check-csp.mjs",
    "check:consent": "node scripts/check-consent-version.mjs",
    "test:captcha-bridge": "node --test infra/captcha-bridge/server.test.mjs",
    "check": "npm run lint && npm run test:captcha-bridge && npm run check:csp && npm run check:consent && echo '\\n✓ Линтеры, CAPTCHA bridge, CSP и версия согласия чисты. Отдельно: WDZ_TEST_JWT=<access_token> npm run security-check (после миграций RLS и при включённой CAPTCHA).'"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1",
    "stylelint": "^16.5.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
