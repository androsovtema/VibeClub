# We Designerz — reverse proxy + авто-TLS (T-LOC).
# Caddy сам получает и обновляет сертификаты Let's Encrypt (ACME HTTP-01),
# нужны только A-записи api.wedesignerz.com и stats.wedesignerz.com → IP VPS
# (см. RUNBOOK.md, шаг 1) и открытые 80/443 в ufw.
{
	email veteristema@gmail.com
	# Не отдавать наружу «Server: Caddy» — на одну зацепку меньше при фингерпринте.
	servers {
		trusted_proxies static private_ranges
	}
}

# Общий набор security-заголовков для обоих доменов.
(security_headers) {
	header {
		# HSTS: браузер год ходит только по HTTPS (кэш ACME уже валиден).
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Не давать угадывать MIME и встраивать в чужие фреймы.
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

api.wedesignerz.com {
	encode gzip
	import security_headers

	# Шаблоны писем для GoTrue: GOTRUE_MAILER_TEMPLATES_* принимает только
	# HTTP(S)-URL (файловый путь GoTrue не читает), поэтому Caddy раздаёт
	# ./mail-templates статикой — auth забирает их отсюда.
	handle_path /mail-templates/* {
		root * /srv/mail-templates
		file_server
	}

	# Этот marker появляется только после успешной выгрузки backup в S3.
	# backup-watchdog удаляет его, если backup старше 26 часов; тогда
	# внешний монитор получит 404 и создаст инцидент.
	@backup_health path /health/backup
	handle @backup_health {
		root * /srv/backup-health
		try_files /backup-ok.txt =404
		file_server
	}

	handle {
		reverse_proxy kong:8000
	}
}

stats.wedesignerz.com {
	encode gzip
	import security_headers
	reverse_proxy umami:3000
}
