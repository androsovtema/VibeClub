# We Designerz — переменные для infra/docker-compose.yml (T-LOC).
# Скопировать в infra/.env (НЕ коммитить — .env в .gitignore) и заполнить.
# Секреты (JWT_SECRET/ANON_KEY/SERVICE_ROLE_KEY/пароли) генерирует
# infra/scripts/gen-keys.mjs — см. RUNBOOK.md, шаг 1.

############
# Postgres
############
POSTGRES_PASSWORD=
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

############
# JWT / API-ключи (легаси HS256 — та же схема, что в js/config.js сейчас)
############
JWT_SECRET=
JWT_EXPIRY=3600
ANON_KEY=
SERVICE_ROLE_KEY=

############
# URLs
############
# Публичный адрес API (через Caddy) — используется Kong/Storage для ссылок.
SUPABASE_PUBLIC_URL=https://api.wedesignerz.com
# Внешний URL Auth-сервиса — для JWT issuer и писем со ссылками подтверждения.
API_EXTERNAL_URL=https://api.wedesignerz.com/auth/v1
# Сайт, на который ведут ссылки в письмах (Site URL в GoTrue).
SITE_URL=https://wedesignerz.com
# Доп. redirect-домены через запятую (staging + прод, если оба нужны).
ADDITIONAL_REDIRECT_URLS=https://wedesignerz.com,https://wedesignerz.com/*

DISABLE_SIGNUP=false

############
# Auth — почта
############
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

ENABLE_EMAIL_SIGNUP=true
# false — email обязателен к подтверждению (как сейчас в Cloud, см. T21).
ENABLE_EMAIL_AUTOCONFIRM=false
# Секрет Cloudflare Turnstile. Хранить только в infra/.env на VPS, заполненным
# в репозиторий не коммитить.
CAPTCHA_SECRET=
# SmartCaptcha server key stays only in infra/.env on the VPS. The allowed
# hosts are checked by captcha-bridge before a token reaches GoTrue.
SMARTCAPTCHA_SERVER_KEY=
SMARTCAPTCHA_ALLOWED_HOSTS=wedesignerz.com,localhost,localhost:8080
CAPTCHA_VERIFY_TIMEOUT_MS=6000

# Темы писем (тексты самих писем — в infra/mail-templates/*.html).
MAILER_SUBJECTS_CONFIRMATION=Подтверди почту — We Designerz
MAILER_SUBJECTS_RECOVERY=Восстановление пароля — We Designerz
MAILER_SUBJECTS_EMAIL_CHANGE=Смена почты — We Designerz

############
# SMTP — Unisender Go (замена Resend)
############
# Хост зависит от площадки кабинета: smtp.go1.unisender.ru или
# smtp.go2.unisender.ru (смотри, где открывается ЛК — go1/go2). Порт 587
# (STARTTLS). Логин — user_id (в ЛК под email), пароль — API-ключ
# («Учётная запись» → «Безопасность» → «API-ключ»).
SMTP_HOST=smtp.go2.unisender.ru
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=noreply@mail.wedesignerz.com
SMTP_SENDER_NAME=We Designerz

############
# Mail-bridge — GoTrue send-email hook → Unisender Go Web API
############
# SMTP-порты Unisender Go недоступны по TCP с VPS (диагностика 2026-07-14,
# см. RUNBOOK.md шаг 6) — письма идут через HTTP-хук GoTrue на mail-bridge,
# тот шлёт через Web API. SMTP_* выше оставлены как фолбэк-конфиг GoTrue,
# реально не используются, пока hook включён.
# Секрет подписи вебхука (standard-webhooks), формат v1,whsec_<base64 32
# байта> — генерируется gen-keys.mjs, используется И в GOTRUE_HOOK_SEND_EMAIL_SECRETS,
# И в самом mail-bridge (одна и та же переменная, отдельно не дублировать).
SEND_EMAIL_HOOK_SECRET=
# Тот же API-ключ Unisender, что и SMTP_PASS выше (площадка выдаёт один
# ключ на оба протокола) — но заведён отдельной переменной, чтобы
# mail-bridge не зависел от SMTP-блока.
UNISENDER_API_URL=https://go2.unisender.ru/ru/transactional/api/v1/email/send.json
UNISENDER_API_KEY=
MAIL_FROM=noreply@mail.wedesignerz.com
MAIL_FROM_NAME=We Designerz
# Базовый URL для ссылки /auth/v1/verify в письмах (без хвостового /).
API_EXTERNAL_BASE=https://api.wedesignerz.com

############
# Storage
############
PG_META_CRYPTO_KEY=
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

############
# Supabase Studio — только через SSH-туннель, не публиковать наружу
############
STUDIO_DEFAULT_ORGANIZATION=We Designerz
STUDIO_DEFAULT_PROJECT=VibeClub Production

############
# Umami (self-host)
############
UMAMI_DB_PASSWORD=
UMAMI_APP_SECRET=

############
# Бэкапы — S3-совместимое хранилище Timeweb
############
# Кабинет Timeweb Cloud → Облачное хранилище → создать бакет + ключи доступа.
BACKUP_S3_ENDPOINT=https://s3.timeweb.cloud
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=ru-1
